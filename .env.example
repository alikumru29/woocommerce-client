# WooCommerce REST API credentials
# Generate from: WP Admin → WooCommerce → Settings → Advanced → REST API → Add key
# Permissions: Read, Write, or Read/Write depending on what you need.

WC_URL=https://your-store.example.com
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional
WC_VERSION=wc/v3
WC_TIMEOUT_MS=30000
WC_RETRIES=3
WC_LOG_LEVEL=info
